# Copy thành .env và điền giá trị thật — KHÔNG commit .env lên Git

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# App
APP_NAME=Travel Chatbot API
APP_VERSION=1.0.0

# LLM — để trống = dùng rule-based offline (không cần API key)
OPENAI_API_KEY=
LLM_MODEL=gpt-3.5-turbo

# CORS — domain frontend được phép gọi (vd: https://your-frontend.vercel.app)
CORS_ORIGINS=*

# Observability
LOG_LEVEL=INFO
